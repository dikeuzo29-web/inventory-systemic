{
  "$schema": "about:blank",
  "name": "Inventory System",
  "short_name": "Inventory",
  "description": "Inventory management progressive web app.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#0d6efd",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/static/image/itekton-logo.jpg",
      "sizes": "192x192",
      "type": "image/jpeg"
    }
  ],
  "screenshots": [
    {
      "src": "/static/image/screenshot-1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Inventory overview"
    }
  ],
  "shortcuts": [
    {
      "name": "Add Item",
      "short_name": "Add",
      "description": "Quickly add a new inventory item",
      "url": "/add-item",
      "icons": [
        {
          "src": "/static/image/shortcut-add.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+inventory",
      "url": "/?uri=%s"
    }
  ]
}
  